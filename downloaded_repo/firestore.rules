rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Public attractions collection
    match /attractions/{attractionId} {
      // Allow public read for catalog
      allow read: if true;
      allow write: if false;
    }
  }
}
